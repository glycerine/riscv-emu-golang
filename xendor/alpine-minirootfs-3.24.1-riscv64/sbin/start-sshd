#!/bin/sh
export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

tag=sshd
log_file=/tmp/sshd-start.log

log_msg() {
	logger -t "$tag" "$*" >/dev/null 2>&1 || true
}

log_output() {
	[ -s "$log_file" ] || return 0
	while IFS= read -r line; do
		[ -n "$line" ] && log_msg "$line"
	done < "$log_file"
	: > "$log_file"
}

require_ed25519_host_key() {
	if [ ! -r "$cfgfile" ]; then
		log_msg "missing sshd config: $cfgfile"
		return 1
	fi

	found_ed25519=no
	while read -r keyword path rest; do
		[ "$keyword" = HostKey ] || continue
		[ -n "$path" ] || continue
		if [ "$path" != /etc/ssh/ssh_host_ed25519_key ]; then
			log_msg "refusing unsupported HostKey: $path"
			return 1
		fi
		found_ed25519=yes
	done < "$cfgfile"

	if [ "$found_ed25519" != yes ]; then
		log_msg "missing HostKey /etc/ssh/ssh_host_ed25519_key"
		return 1
	fi
	if [ ! -f /etc/ssh/ssh_host_ed25519_key ]; then
		log_msg "missing /etc/ssh/ssh_host_ed25519_key"
		return 1
	fi
	return 0
}

cfgfile=/etc/ssh/sshd_config
command=/usr/sbin/sshd
command_args=

[ -r /etc/conf.d/sshd ] && . /etc/conf.d/sshd

: "${cfgfile:=${SSHD_CONFIG:-${SSHD_CONFDIR:-/etc/ssh}/sshd_config}}"
: "${command:=${SSHD_BINARY:-/usr/sbin/sshd}}"
: "${command_args:=${SSHD_OPTS:-}}"

mkdir -p /run/sshd /tmp /var/log
: > "$log_file" || exit 0

if ! require_ed25519_host_key; then
	rm -f "$log_file"
	exit 0
fi

# Intentionally allow word splitting in command_args, matching OpenRC's script.
# shellcheck disable=SC2086
if ! "$command" -t -f "$cfgfile" $command_args >"$log_file" 2>&1; then
	log_msg "configuration check failed"
	log_output
	rm -f "$log_file"
	exit 0
fi

# shellcheck disable=SC2086
if ! "$command" -f "$cfgfile" $command_args >"$log_file" 2>&1; then
	log_msg "failed to start"
	log_output
	rm -f "$log_file"
	exit 0
fi

log_output
rm -f "$log_file"
exit 0
