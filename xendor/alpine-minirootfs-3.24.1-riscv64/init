#!/bin/sh
export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

mkdir -p /proc /sys /dev /host /tmp /run

mount -t proc none /proc 2>/dev/null || true
mount -t sysfs none /sys 2>/dev/null || true
mount -t devtmpfs none /dev 2>/dev/null || true

chmod 1777 /tmp
mount -t hostfs none /host -o /

# Bring up networking only when a virtio-net interface has actually bound.
# Keep this bounded so boot reaches a shell even if DHCP is unavailable.
EMUNET_IFACE=
for netdev in /sys/class/net/*; do
	[ -e "$netdev" ] || continue
	iface="${netdev##*/}"
	[ "$iface" = lo ] && continue
	driver="$(readlink "$netdev/device/driver" 2>/dev/null || true)"
	case "$driver" in
	*/virtio_net)
		EMUNET_IFACE="$iface"
		break
		;;
	esac
done

if [ -z "$EMUNET_IFACE" ]; then
	if ip link show eth0 >/dev/null 2>&1 || /bin/busybox ifconfig eth0 >/dev/null 2>&1; then
		EMUNET_IFACE=eth0
	fi
fi

if [ -n "$EMUNET_IFACE" ]; then
	NET_IFACE="$EMUNET_IFACE" netup -n -T 1 -t 5 || true

        # better dns vs 100.100.100.100 from tailscale
        printf 'nameserver 1.1.1.1\n' > /etc/resolv.conf
        # without current time, certificate checks fail preventing apk add
        ntpd -n -q -p time.cloudflare.com
        date -u
fi

if [ -d /sys/class/net/lo ]; then
	ip link set lo up 2>/dev/null || ifconfig lo up
fi

echo ""
echo "=== RISC-V Alpine initramfs booted ==="
echo ""
if [ -e /dev/ttyS1 ]; then
	(
		while [ -e /dev/ttyS1 ]; do
			setsid /bin/sh -c 'exec /bin/sh -i </dev/ttyS1 >/dev/ttyS1 2>&1'
		done
	) &
fi
exec setsid /bin/sh -c 'exec /bin/sh -i </dev/ttyS0 >/dev/ttyS0 2>&1'
