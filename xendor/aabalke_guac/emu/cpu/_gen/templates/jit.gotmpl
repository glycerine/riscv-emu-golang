type Jit struct {
	*gojit.Assembler
	Cpu *Cpu

    BlockCache *BlockCache
    Pages []*Page
	Metrics [ADDRESS_SPACE >> PAGE_SHIFT][]uint32
	invalidPages []*Page

	// used for testing individual instructions
	testFunc func()

    LoopThreshold uint32 
    PageShift uint32
    PageMask uint32
