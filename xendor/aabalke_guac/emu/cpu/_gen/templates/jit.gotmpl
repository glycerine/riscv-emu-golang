    } else {
        for {
            op = *(*uint32)(unsafe.Add(p, i*4))

            {{if .A9 -}}
            if length >= config.Conf.Jit.BatchInstA9 {
            {{else -}}
            if length >= config.Conf.Jit.BatchInstA7 {
                {{end}}
                break
            }

            if isB(op) && op >> 28 == 0xE {

                if immLoop := op == 0xEAFFFFFE; immLoop {
                    j.Cpu.Halted = true
                    j.BlockCache.PushTail(newBlock)
                    page.Blocks[blockIdx] = j.BlockCache.SkipBlock
                    return
                }

                tempPc += uint32((int32(op)<<8)>>6) + 8

                    if link := (op>>24)&1 != 0; link {
                        j.Movl(j.REG(PC), gojit.Eax)
                            j.Add(gojit.Imm(4), gojit.Eax)
                            j.Movl(gojit.Eax, j.REG(14))

                    }

                j.Movl(gojit.Imm(tempPc), j.REG(PC))

                i = 0

                p, ok = j.Cpu.mem.ReadPtr(tempPc, {{.A9}})
                if !ok {
                    j.BlockCache.PushTail(newBlock)
                    page.Blocks[blockIdx] = j.BlockCache.SkipBlock
                    return
